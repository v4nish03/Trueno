# Base de Datos
# Para desarrollo local con SQLite (default)
DATABASE_URL=sqlite:///./trueno.db

# Para producción con PostgreSQL
# DATABASE_URL=postgresql://usuario:password@localhost:5432/trueno_motors

# Telegram - Configuración del Bot
# Obtén el token hablando con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram - Números para Alertas (hasta 2 números, separados por coma)
# Usa @userinfobot para obtener tus IDs de usuario
TELEGRAM_ALERTAS_NUMEROS=123456789,987654321

# Telegram - Número para Backups (solo 1 número)
TELEGRAM_BACKUP_NUMERO=123456789

# Telegram - Habilitar/Desabilitar sistema (true/false)
TELEGRAM_HABILITADO=false

# Impresora - Nombre de la impresora térmica
# Usa "lpstat -p" para ver impresoras disponibles
IMPRESORA_TERMINO=TM-T20II

# Servidor
# Host para el servidor FastAPI (0.0.0.0 para red local)
HOST=0.0.0.0

# Puerto para el servidor FastAPI
PORT=8000

# Entorno (development/production)
ENVIRONMENT=development

# Logs
# Nivel de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Seguridad
# Clave secreta para JWT (genera una con: openssl rand -hex 32)
SECRET_KEY=tu_clave_secreta_aqui_generada_con_openssl

# CORS
# Orígenes permitidos para CORS (separados por coma)
# Para desarrollo: http://localhost:3000,http://localhost:5173
# Para producción: https://tudominio.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000
